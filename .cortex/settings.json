{
  "$schema": "https://docs.snowflake.com/cortex-code/settings.schema.json",
  "_comment": "SnowRetail ハンズオン用 Hooks サンプル。AGENTS.md (ソフトガバナンス) を補完するハードガバナンス層。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "snowflake_sql_execute",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cortex/hooks/block_dangerous_sql.sh",
            "timeout": 30,
            "enabled": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cortex/hooks/block_dangerous_bash.sh",
            "timeout": 30,
            "enabled": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "snowflake_sql_execute",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cortex/hooks/log_sql.sh",
            "timeout": 15,
            "enabled": true
          }
        ]
      }
    ]
  }
}
